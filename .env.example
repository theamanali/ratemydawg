# Shared — all three layers read this
DATABASE_URL=postgresql://user:password@host:port/dbname

# Pipeline — rmp_scraper.py
RMP_AUTH=Authorization header value for the RMP GraphQL API

# Pipeline — cec_scraper.py (all optional, for push notifications)
NTFY_URL=https://your-ntfy-instance.com
NTFY_TOPIC=your-topic
NTFY_TOKEN=your-token

# API — Azure AD (MSAL) for UW NetID OAuth
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_TENANT_ID=uw.edu
# Provide either the file path or raw PEM content for the private key and cert:
AZURE_KEY_PATH=/path/to/key.pem
# AZURE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
AZURE_CERT_PATH=/path/to/cert.pem
# AZURE_CERT=-----BEGIN CERTIFICATE-----...

# API — JWT
JWT_SECRET=a-long-random-secret

# API — optional
TRUSTED_PROXY=1                          # set on Railway to read real IPs from CF-Connecting-IP
CORS_ORIGINS=https://myplan.uw.edu       # comma-separated; default is myplan.uw.edu
CORS_ORIGIN_REGEX=chrome-extension://.*  # default allows all extension origins
